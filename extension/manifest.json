{
  "manifest_version": 3,
  "name": "ZeeApply — Apply Assistant",
  "version": "0.1.0",
  "description": "Auto-fills your name, email, links, work-auth statement and ZeeApply-drafted cover letter on Greenhouse, Lever, and Ashby apply pages.",
  "action": {
    "default_title": "ZeeApply",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://jobs.ashbyhq.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://jobs.ashbyhq.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

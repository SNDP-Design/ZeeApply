# Required: Gemini API key (used for scoring + cover letter drafting)
# Get one free at https://aistudio.google.com/apikey  (no credit card)
GEMINI_API_KEY=

# Optional: gate the app with a login (only set if you deploy publicly)
# APP_USERNAME=
# APP_PASSWORD=

# Optional: Adzuna (Indeed-style aggregated listings)
# Free signup: https://developer.adzuna.com  (250 calls/month free tier)
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# ADZUNA_COUNTRY=us  # us, gb, in, ca, au, de, fr, etc.

# Optional: USAJobs (US federal jobs)
# Free signup: https://developer.usajobs.gov/APIRequest/Index
# USAJOBS_EMAIL=you@example.com
# USAJOBS_API_KEY=
